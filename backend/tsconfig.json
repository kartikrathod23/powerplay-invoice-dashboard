{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "types": ["node","jest"],

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*","tests/**/*"]
}